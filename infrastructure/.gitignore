# Terraform state (use remote backend in production)
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive variable files (tfvars may contain secrets)
# Uncomment the line below if your .tfvars contain secrets
# *.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
